root = "."
tmp_dir = "tmp"

[build]
  bin = "./tmp/{{.ProjectName}}"
  cmd = "go build -o ./tmp/{{.ProjectName}} ./cmd/server"
  delay = 1000
  exclude_dir = ["tmp", "vendor", "testdata", "node_modules", "backups", "static"]
  exclude_regex = ["_templ\\.go$", "_test\\.go$"]
  include_ext = ["go"]
  kill_delay = "0s"
  log = "build-errors.log"
  send_interrupt = true
  stop_on_error = true

[color]
  app     = ""
  build   = "yellow"
  main    = "magenta"
  runner  = "green"
  watcher = "cyan"

[log]
  main_only = false
  time      = false

[misc]
  clean_on_exit = false

[screen]
  clear_on_rebuild = true
  keep_scroll      = true

# ── Help ──────────────────────────────────────────────────────────────────────

## help: display this help message
help:
	@echo "Usage: make [target]"
	@echo ""
	@grep -E '^##' $(MAKEFILE_LIST) | sed -e 's/## //g' | column -t -s ':'
